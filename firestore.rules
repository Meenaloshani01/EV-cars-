rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write only their own profile document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Users can read/write their own trips subcollection
      match /trips/{tripId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
